{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "console_title_template": " {{ .Folder }} :: {{ if .Root -}}Admin{{ end -}}",
  "palette": {
    "red": "#F7768E",
    "orange": "#FF9E64",
    "yellow": "#E0AF68",
    "sand": "#CFC9C2",
    "green": "#9ECE6A",
    "teal": "#73DACA",
    "aqua": "#B4F9F8",
    "cyan": "#2AC3DE",
    "sky": "#7DCFFF",
    "blue": "#7AA2F7",
    "purple": "#BB9AF7",
    "fg": "#C0CAF5",
    "fg-dark": "#A9B1D6",
    "comment": "#565F89",
    "terminal-black": "#414868",
    "bg-storm": "#24283B",
    "bg-night": "#1A1B26"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": "\uDB82\uDD04 ",
          "foreground": "p:sky"
        },
        {
          "type": "path",
          "style": "plain",
          "options": {
            "style": "full"
          },
          "template": "<b>{{ .Path }}</b> ",
          "foreground": "p:purple"
        },
        {
          "type": "text",
          "style": "plain",
          "template": "{{ if .Segments.Contains \"git\" }}\uDB80\uDC55{{ end }} ",
          "foreground": "p:fg-dark"
        },
        {
          "type": "git",
          "alias": "git",
          "style": "plain",
          "options": {
            "fetch_status": true,
            "branch_icon": "\uDB81\uDE2C "
          },
          "template": "({{ .HEAD }})",
          "foreground": "p:sky",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:red{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0)         }}p:yellow{{ end }}",
            "{{ if gt .Ahead 0                              }}p:orange{{ end }}",
            "{{ if gt .Behind 0                             }}p:aqua{{ end }}"
          ]
        },
        {
          "type": "status",
          "style": "plain",
          "template": " \uf00d",
          "foreground": "p:red"
        }
      ]
    },
    {
      "type": "prompt",
      "newline": true,
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": "\uDB80\uDC55 ",
          "foreground": "p:orange"
        }
      ]
    }
  ],
  "secondary_prompt": {
    "template": "\uDB80\uDC55 ",
    "foreground": "p:yellow"
  },
  "terminal_background": "p:terminal-black"
}
